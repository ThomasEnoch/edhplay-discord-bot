{
  "name": "edhplay-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot that schedules Commander (EDH) pods and launches games on EDH Play",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/smoke.ts && tsx test/persistence.ts && tsx test/buttons.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
