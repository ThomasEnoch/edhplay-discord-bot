# Discord application credentials (https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
# Optional: register commands instantly to one guild during development.
# Leave blank to register globally (can take up to an hour to propagate).
DISCORD_GUILD_ID=

# EDH Play backend (discovered via dev tools)
EDHPLAY_API_BASE=https://api.edhplay.com
EDHPLAY_WEB_BASE=https://edhplay.com

# SQLite database file for pods and linked-account tokens. Created on first run.
DB_PATH=./data/edhplay.db
